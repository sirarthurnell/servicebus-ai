{
  "UserConfig": {
    "Namespaces": [
      {
        "Name": "sbemulatorns",
        "Topics": [
          {
            "Name": "events",
            "Properties": {
              "DefaultMessageTimeToLive": "PT1H"
            },
            "Subscriptions": [
              {
                "Name": "summarizer",
                "Properties": {
                  "LockDuration": "PT1M",
                  "MaxDeliveryCount": 10,
                  "DeadLetteringOnMessageExpiration": true,
                  "RequiresSession": false
                }
              },
              {
                "Name": "audit",
                "Properties": {
                  "LockDuration": "PT1M",
                  "MaxDeliveryCount": 10,
                  "DeadLetteringOnMessageExpiration": true,
                  "RequiresSession": false
                }
              }
            ]
          }
        ]
      }
    ],
    "Logging": { "Type": "File" }
  }
}